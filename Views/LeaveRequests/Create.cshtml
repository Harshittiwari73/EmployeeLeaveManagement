@model EmployeeLeaveManagement.Models.LeaveRequest
@{
    ViewData["Title"] = "Apply Leave";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <div class="d-flex align-items-center gap-3">
                        <a asp-action="Index" class="btn btn-light rounded-circle"><i class="bi bi-arrow-left"></i></a>
                        <h4 class="fw-bold mb-0">Apply for Leave</h4>
                    </div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">SELECT EMPLOYEE</label>
                            <select asp-for="EmployeeId" asp-items="ViewBag.EmployeeId" class="form-select rounded-3">
                                <option value="">-- Select --</option>
                            </select>
                            <span asp-validation-for="EmployeeId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">LEAVE TYPE</label>
                            <select asp-for="LeaveTypeId" asp-items="ViewBag.LeaveTypeId" class="form-select rounded-3">
                                <option value="">-- Select --</option>
                            </select>
                            <span asp-validation-for="LeaveTypeId" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">FROM DATE</label>
                                <input asp-for="FromDate" type="date" class="form-control rounded-3" />
                                <span asp-validation-for="FromDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">TO DATE</label>
                                <input asp-for="ToDate" type="date" class="form-control rounded-3" />
                                <span asp-validation-for="ToDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">REASON FOR LEAVE</label>
                            <textarea asp-for="Reason" class="form-control rounded-3" rows="3" placeholder="Explain your reason here..."></textarea>
                            <span asp-validation-for="Reason" class="text-danger small"></span>
                        </div>

                        <hr class="text-muted my-4 opacity-25">

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold">Submit Application</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}