@model IEnumerable<EmployeeLeaveManagement.Models.LeaveRequest>
@using EmployeeLeaveManagement.Helpers
@{
    bool canAdd = await PermissionHelper.HasPermission(User, "LeaveRequest", "Create", Context);
}

<div class="table-container">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Leave Requests</h3>
            <p class="text-muted small mb-0">Manage and track your leave applications</p>
        </div>

        @if (canAdd)
        {
            <button type="button"
                    class="btn btn-primary d-flex align-items-center gap-2 px-4 py-2 shadow-sm rounded-pill"
                    data-bs-toggle="modal"
                    data-bs-target="#applyLeaveModal">
                <i class="bi bi-plus-circle-fill"></i>
                <span>Apply for Leave</span>
            </button>
        }
    </div>

    <div class="filter-row mb-3 d-flex flex-wrap gap-2">

        <input type="text"
               id="employeeSearch"
               class="form-control filter-input"
               placeholder="Search Employee..."
               value="@ViewBag.EmployeeSearch"
               style="max-width: 220px;" />

        <input type="text"
               id="leaveTypeSearch"
               class="form-control filter-input"
               placeholder="Leave Type..."
               value="@ViewBag.LeaveTypeSearch"
               style="max-width: 180px;" />

        <input type="date"
               id="fromDateSearch"
               class="form-control filter-input"
               value="@ViewBag.FromDateSearch"
               style="max-width: 170px;" />

        <select id="statusSearch"
                class="form-select filter-input"
                style="max-width: 150px;">

            <option value="">Status</option>
            <option value="Approved" selected="@(ViewBag.StatusSearch == "Approved")">Approved</option>
            <option value="Rejected" selected="@(ViewBag.StatusSearch == "Rejected")">Rejected</option>
            <option value="Pending" selected="@(ViewBag.StatusSearch == "Pending")">Pending</option>

        </select>

        <button id="applyFilters"
                class="btn btn-primary px-3">
            <i class="bi bi-filter"></i> Apply
        </button>

        <button id="resetFilters"
                class="btn btn-outline-secondary px-3">

            <i class="bi bi-arrow-clockwise"></i>

        </button>

    </div>
    <div class="premium-table-scroll">

        <table class="table table-hover align-middle">

            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3"><i class="bi bi-person me-2"></i>Employee</th>
                    <th class="py-3"><i class="bi bi-card-list me-2"></i>Leave Type</th>
                    <th class="py-3"><i class="bi bi-calendar-range me-2"></i>Duration</th>
                    <th class="py-3"><i class="bi bi-chat-left-text me-2"></i>Reason</th>
                    <th class="py-3"><i class="bi bi-info-circle me-2"></i>Status</th>
                    <th class="pe-4 py-3 text-end"><i class="bi bi-clock-history me-2"></i>Applied Date</th>
                </tr>
            </thead>

            <tbody>

                @if (Model != null && Model.Any())

                {
                    @foreach (var item in Model)

                    {
                        <tr>

                            <td>

                                <div class="fw-semibold">

                                    @(item.Employee?.EmployeeName ?? "N/A")

                                </div>

                            </td>

                            <td>

                                <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill">

                                    @(item.LeaveType?.LeaveTypeName ?? "N/A")

                                </span>

                            </td>
                            <td>

                                <span class="small fw-semibold">

                                    @(item.FromDate?.ToString("dd MMM"))

                                    -

                                    @(item.ToDate?.ToString("dd MMM yyyy"))

                                </span>

                            </td>

                            <td>

                                <span class="text-muted small">

                                    @(string.IsNullOrEmpty(item.Reason)
                                        ? "No reason provided"
                                        : item.Reason.Length > 40
                                        ? item.Reason.Substring(0, 37) + "..."
                                        : item.Reason)

                                </span>

                            </td>

                            <td>

                                @if (item.Status == "Approved")
                                {
                                    <span class="badge bg-success-soft px-3 py-2 rounded-pill d-inline-flex align-items-center gap-1">
                                        <i class="bi bi-check-circle-fill small"></i>
                                        Approved
                                    </span>
                                }
                                else if (item.Status == "Rejected")
                                {
                                    <span class="badge bg-danger-soft px-3 py-2 rounded-pill d-inline-flex align-items-center gap-1">
                                        <i class="bi bi-x-circle-fill small"></i>
                                        Rejected
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-soft px-3 py-2 rounded-pill d-inline-flex align-items-center gap-1">
                                        <i class="bi bi-hourglass-split small"></i>
                                        Pending
                                    </span>
                                }

                            </td>
                            <td class="text-end"
                                data-date="@item.AppliedDate?.ToString("yyyy-MM-dd")">

                                <span class="small fw-semibold text-muted">

                                    @(item.AppliedDate?.ToString("dd MMM yyyy"))

                                </span>

                            </td>

                        </tr>
                    }
                }



                else



                {
                    <tr>

                        <td colspan="6" class="text-center py-5">

                            <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>

                            <h6 class="fw-bold text-muted">

                                No Leave Requests Found

                            </h6>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>
<div class="modal fade"
     id="applyLeaveModal"
     tabindex="-1"
     aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-primary text-white border-0 py-3 px-4">
                <div>
                    <h5 class="modal-title fw-bold mb-0">Apply for Leave</h5>
                    <p class="text-white-50 small mb-0">Fill all details to submit leave request</p>
                </div>
                <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">

                <form id="applyLeaveForm">
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-uppercase text-muted mb-2">Employee</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-person text-primary"></i></span>
                                <select id="employeeId" class="form-select border-start-0 ps-0" required>
                                    <option value="">Select Employee</option>
                                    @foreach (var emp in (IEnumerable<Employee>)ViewBag.Employees)
                                    {
                                        <option value="@emp.EmployeeId">@emp.EmployeeName</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-uppercase text-muted mb-2">Leave Type</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-card-list text-primary"></i></span>
                                <select id="leaveTypeId" class="form-select border-start-0 ps-0" required>
                                    <option value="">Select Leave Type</option>
                                    @foreach (var lt in (IEnumerable<LeaveType>)ViewBag.LeaveTypes)
                                    {
                                        <option value="@lt.LeaveTypeId">@lt.LeaveTypeName</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-uppercase text-muted mb-2">From Date</label>
                            <div class="input-group has-validation">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-calendar-event text-primary"></i></span>
                                <input type="date" id="fromDate" class="form-control border-start-0 ps-0" required />
                                <div class="invalid-feedback" id="fromDateError"></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-uppercase text-muted mb-2">To Date</label>
                            <div class="input-group has-validation">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-calendar-check text-primary"></i></span>
                                <input type="date" id="toDate" class="form-control border-start-0 ps-0" required />
                                <div class="invalid-feedback" id="toDateError"></div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold small text-uppercase text-muted mb-2">Reason</label>
                        <div class="input-group has-validation">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-chat-dots text-primary"></i></span>
                            <textarea id="reason" class="form-control border-start-0 ps-0" rows="3" placeholder="Please explain your reason for leave..." required></textarea>
                            <div class="invalid-feedback" id="reasonError"></div>
                        </div>
                    </div>
                  
                    <div class="d-flex justify-content-end gap-2 mt-2">
                        <button type="button" class="btn btn-light rounded-pill px-4 text-muted fw-semibold" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" id="btnSubmit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm d-flex align-items-center gap-2">
                            <span>Submit Request</span>
                            <span class="spinner-border spinner-border-sm d-none" id="submitSpinner"></span>
                        </button>
                    </div>

                </form>

            </div>

        </div>

    </div>

</div>
@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/leaverequest/leaverequest.js"></script>

}