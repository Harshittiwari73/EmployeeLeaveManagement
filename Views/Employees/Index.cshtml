@model IEnumerable<EmployeeLeaveManagement.Models.Employee>
@using EmployeeLeaveManagement.Services
@using System.Security.Claims
@using EmployeeLeaveManagement.Helpers

@{
    bool canAdd = await PermissionHelper.HasPermission(User, "Employee", "Create", Context);
    bool canEdit = await PermissionHelper.HasPermission(User, "Employee", "Edit", Context);
    bool canDelete = await PermissionHelper.HasPermission(User, "Employee", "Delete", Context);
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<div class="table-container">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Employee</h3>
        @if (canAdd)
        {
            <button class="btn btn-primary" id="addEmployeeBtn" data-bs-toggle="modal" data-bs-target="#employeeModal">
                <i class="bi bi-plus-lg me-1"></i> Add Employee
            </button>
        }
    </div>

    <div class="filter-row mb-3 d-flex flex-wrap gap-2">
        <input type="text" id="nameSearch" class="form-control filter-input" placeholder="Search Name..." value="@ViewBag.Name" style="max-width: 200px;" />
        <input type="text" id="emailSearch" class="form-control filter-input" placeholder="Search Email..." value="@ViewBag.Email" style="max-width: 200px;" />
        <input type="text" id="departmentSearch" class="form-control filter-input" placeholder="Department..." value="@ViewBag.Department" style="max-width: 150px;" />
        <input type="date" id="joiningDateSearch" class="form-control filter-input" value="@ViewBag.JoiningDate" style="max-width: 150px;" />
        <select id="statusSearch" class="form-select filter-input" style="max-width: 130px;">
            <option value="">Status</option>
            <option value="active" selected="@(ViewBag.Status == "active")">Active</option>
            <option value="inactive" selected="@(ViewBag.Status == "inactive")">Inactive</option>
        </select>
        <button id="applyFilters" class="btn btn-primary px-3">
            <i class="bi bi-filter"></i> Apply
        </button>
        <button id="resetFilters" class="btn btn-outline-secondary px-3">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>
    <div class="premium-table-scroll">
        <table class="table table-hover">

            <thead>

                <tr>

                    <th class="sortable" data-column="0">

                        Name

                    </th>

                    <th class="sortable" data-column="1">

                        Email

                    </th>

                    <th class="sortable" data-column="2">

                        Department

                    </th>

                    <th class="sortable" data-column="3">

                        Joining Date

                    </th>

                    <th class="sortable" data-column="4">

                        Status

                    </th>

                    <th>
                        Action
                    </th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.EmployeeName</td>

                        <td>@item.Email</td>

                        <td>@item.Department</td>

                        <td data-date="@item.JoiningDate?.ToString("yyyy-MM-dd")">

                            @(item.JoiningDate?.ToString("dd MMM yyyy"))

                        </td>
                        <td>

                            @if (item.IsActive == true)
                            {
                                <span class="badge bg-success">
                                    Active
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Inactive
                                </span>
                            }

                        </td>

                        <td class="gap-2">
                            <div class="d-flex gap-2">
                                @if (canEdit)
                                {
                                    <button class="btn btn-outline-warning btn-sm editBtn p-0 d-flex align-items-center justify-content-center"
                                            style="width: 32px; height: 32px;"
                                            data-id="@item.EmployeeId">
                                        <i class="bi bi-pencil-fill"></i>
                                    </button>
                                }

                                @if (canDelete)
                                {
                                    <button class="btn btn-outline-danger btn-sm deleteBtn p-0 d-flex align-items-center justify-content-center"
                                            style="width: 32px; height: 32px;"
                                            data-id="@item.EmployeeId">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                }
                            </div>
                        </td>

                    </tr>
                }

            </tbody>

        </table>
    </div>

</div>

<div class="modal fade"
     id="employeeModal"
     tabindex="-1">

    <div class="modal-dialog modal-dialog-centered modal-lg">

        <div class="modal-content border-0 shadow-lg rounded-4">

            <div class="modal-header border-0 px-4 pt-4">

                <div>

                    <h4 class="fw-bold mb-1">
                        Employee
                    </h4>
                </div>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body px-4 pb-4">

                <form id="employeeForm">

                    <input type="hidden"
                           id="EmployeeId"
                           name="EmployeeId" />

                    <div class="row">

                        <div class="col-md-6 mb-4">

                            <label class="form-label fw-semibold">
                                Employee Name
                            </label>

                            <input type="text"
                                   name="EmployeeName"
                                   id="EmployeeName"
                                   class="form-control form-control-lg"
                                   placeholder="Enter employee name" />

                            <span class="text-danger small" id="nameError"></span>

                        </div>

                        <div class="col-md-6 mb-4">

                            <label class="form-label fw-semibold">
                                Email Address
                            </label>

                            <input type="email"
                                   name="Email"
                                   id="Email"
                                   class="form-control form-control-lg"
                                   placeholder="Enter email" />

                            <span class="text-danger small" id="emailError"></span>

                        </div>

                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-4">

                            <label class="form-label fw-semibold">
                                Department
                            </label>

                            <input type="text"
                                   name="Department"
                                   class="form-control form-control-lg"
                                   placeholder="Enter department" />

                        </div>

                        <div class="col-md-6 mb-4">

                            <label class="form-label fw-semibold">
                                Joining Date
                            </label>

                            <input type="date"
                                   name="JoiningDate"
                                   id="JoiningDate"
                                   class="form-control form-control-lg" />

                            <span class="text-danger small" id="dateError"></span>

                        </div>

                    </div>

                    <div class="form-check form-switch mt-2">

                        <input class="form-check-input"
                               type="checkbox"
                               id="IsActive"
                               name="IsActive"
                               value="true">

                        <label class="form-check-label fw-semibold">

                            Active Employee

                        </label>

                    </div>

                </form>

            </div>

            <div class="modal-footer border-0 px-4 pb-4">

                <button type="button"
                        class="btn btn-light px-4"
                        data-bs-dismiss="modal">

                    Cancel

                </button>

                <button type="button"
                        id="saveEmployee"
                        class="btn btn-primary px-4">

                    Save 

                </button>

            </div>

        </div>

    </div>

</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/employee/employee.js"></script>
}