@model UserViewModel
@{
    ViewData["Title"] = "Add User";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <div class="d-flex align-items-center gap-3">
                        <a asp-action="Index" class="btn btn-light rounded-circle"><i class="bi bi-arrow-left"></i></a>
                        <h4 class="fw-bold mb-0">Add New User</h4>
                    </div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" id="createUserForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label asp-for="Username" class="form-label small fw-bold">USERNAME</label>
                                <input asp-for="Username" class="form-control rounded-3" placeholder="e.g. john_doe" />
                                <span asp-validation-for="Username" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label asp-for="Email" class="form-label small fw-bold">EMAIL ADDRESS</label>
                                <input asp-for="Email" class="form-control rounded-3" placeholder="john@example.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label small fw-bold">PHONE NUMBER</label>
                                <input asp-for="PhoneNumber" class="form-control rounded-3" placeholder="Optional" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="RoleId" class="form-label small fw-bold">USER ROLE</label>
                                <select asp-for="RoleId" asp-items="ViewBag.Roles" class="form-select rounded-3">
                                    <option value="">Select Role</option>
                                </select>
                                <span asp-validation-for="RoleId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-12">
                                <label asp-for="Password" class="form-label small fw-bold">PASSWORD</label>
                                <div class="input-group">
                                    <input asp-for="Password" type="password" id="passwordInput" class="form-control rounded-start-3" placeholder="At least 6 characters" />
                                    <button class="btn btn-outline-secondary rounded-end-3" type="button" onclick="togglePassword()">
                                        <i class="bi bi-eye" id="toggleIcon"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="text-muted my-4 opacity-25">

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold">Create User</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword() {
            const passwordInput = document.getElementById('passwordInput');
            const toggleIcon = document.getElementById('toggleIcon');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }
    </script>
}
